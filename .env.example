# Rename this file to .env and fill in your own API keys

# OMDB API key (free) — https://www.omdbapi.com/apikey.aspx
# 1,000 requests/day on the free tier
VITE_OMDB_KEY=your_omdb_key_here

# TMDB API key (free) — https://www.themoviedb.org/settings/api
# Needed for: real trailer embeds, cast photos, backdrops
# Without this key the app still works — trailers fall back to YouTube search
VITE_TMDB_KEY=your_tmdb_key_here
